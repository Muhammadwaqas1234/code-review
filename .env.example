# Copy to .env and fill in your values.

# Which LLM backend to use: "openai", "openrouter", or "anthropic"
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys) — required when LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter (https://openrouter.ai/keys) — required when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic (https://console.anthropic.com) — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional model overrides (defaults suit the active provider)
# SMART_MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini
